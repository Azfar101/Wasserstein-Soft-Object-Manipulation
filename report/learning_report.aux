\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces One state, four representations, all real data through the trained model. (a)~the simulated world; (b)~the 35 numbers the policy acts on, color-grouped; (c)~the soil mass distribution $\mu $ --- the objective's entire universe, summing to exactly 1; (d)~the state's position on the learned latent map, with four skill episodes traced for context (star $=$ terminal). Note in (d) that one direction ($+e_1$) barely moves from the start: a \emph  {dead direction} on this terrain, honestly visible.}}{16}{figure.1}\protected@file@percent }
\newlabel{fig:representation}{{1}{16}{One state, four representations, all real data through the trained model. (a)~the simulated world; (b)~the 35 numbers the policy acts on, color-grouped; (c)~the soil mass distribution $\mu $ --- the objective's entire universe, summing to exactly 1; (d)~the state's position on the learned latent map, with four skill episodes traced for context (star $=$ terminal). Note in (d) that one direction ($+e_1$) barely moves from the start: a \emph {dead direction} on this terrain, honestly visible}{figure.1}{}}
